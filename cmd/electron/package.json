{
  "name": "grroxy",
  "version": "2026.4.2",
  "author": {
    "name": "Gitesh Sharma",
    "email": "gitesh@grroxy.com"
  },
  "main": "./src/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.glitchedgitz.grroxy",
    "productName": "grroxy",
    "extraResources": [
      {
        "from": "bin/${os}/${arch}/",
        "to": "bin",
        "filter": [
          "grroxy*",
          "cook*"
        ]
      },
      {
        "from": "../../grx/frontend/dist/",
        "to": "frontend"
      }
    ],
    "files": [
      "src/index.js",
      "src/preload.js",
      "src/icons/**/*"
    ],
    "artifactName": "${productName}-${os}-${arch}-${version}.${ext}",
    "mac": {
      "icon": "src/icons/grroxy.png",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "src/icons/grroxy.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "src/icons/grroxy.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
